{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Normalized Security Finding",
  "description": "Schema unificado para hallazgos DevSecOps - TG Universidad del Valle 2026",
  "type": "object",
  "required": ["id", "tool", "severity", "title", "description", "category"],
  "properties": {
    "id": { "type": "string" },
    "tool": { "type": "string", "enum": ["semgrep", "trivy", "zap", "nuclei"] },
    "tool_type": { "type": "string", "enum": ["SAST", "SCA", "DAST", "PENTEST"] },
    "severity": { "type": "string", "enum": ["CRITICAL", "HIGH", "MEDIUM", "LOW", "INFO"] },
    "cvss_score": { "type": ["number", "null"] },
    "title": { "type": "string" },
    "description": { "type": "string" },
    "category": { "type": "string" },
    "cwe": { "type": ["string", "null"] },
    "location": {
      "type": "object",
      "properties": {
        "file": { "type": ["string", "null"] },
        "line": { "type": ["integer", "null"] },
        "endpoint": { "type": ["string", "null"] },
        "method": { "type": ["string", "null"] }
      }
    },
    "evidence": { "type": "string" },
    "remediation": { "type": "string" },
    "raw": { "type": "object" }
  }
}
